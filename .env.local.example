# Exemple de configuration — copier en `.env.local` puis remplir.
# `.env.local` et `.secrets/` sont gitignorés : ne JAMAIS committer les vraies valeurs.

# --- Service-account (un des deux selon l'environnement) ---
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/service-account.json   # dev (chemin vers le JSON)
GOOGLE_SA_KEY_B64=<base64 du JSON>                               # prod Vercel (clé encodée en base64)

# --- Boîtes impersonnées (délégation domaine) ---
GMAIL_IMPERSONATE=pointage@bleucitron.net
JUSTIF_MAILBOX=azais@bleucitron.net

# --- Sources de données ---
BCD_SHEET_FILE_ID=1PXay_SqirJyT1P6IXS2iSVN5J9TMM_ffZdj2ZS6FcTI   # annuaire matricule
POINTAGE_SHEET_FILE_ID=...                                        # suivi relances
JUSTIF_DRIVE_FOLDER=15ucT77NBT_30rVagMfpfhZDssmf_NpxU             # archivage justificatifs

# --- SSO Google ---
AUTH_GOOGLE_ID=...apps.googleusercontent.com
AUTH_GOOGLE_SECRET=...
AUTH_SECRET=...                                                  # openssl rand -base64 32
AUTH_HOSTED_DOMAIN=bleucitron.net

# --- Endpoints backend (cron) ---
CRON_SECRET=...                                                  # openssl rand -hex 32

# --- PIMS (phase 2 — relances) ---
PIMS_BASE_URL=...
PIMS_USERNAME=...
PIMS_PASSWORD=...
